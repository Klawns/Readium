# Docker image no Docker Hub:
# - base: imagem menor, OCR heuristico
# - ocr: inclui OCRmyPDF + Tesseract
READIUM_IMAGE_REPOSITORY=klawns/readium
READIUM_IMAGE_TAG=base

APP_PORT=7717
APP_DATABASE_URL=jdbc:sqlite:data/db/library.db
APP_STORAGE_PATH=data/books

# Translation provider: MYMEMORY or LIBRETRANSLATE
APP_TRANSLATION_PROVIDER=MYMEMORY
APP_TRANSLATION_MYMEMORY_URL=https://api.mymemory.translated.net/get
APP_TRANSLATION_LIBRE_URL=http://localhost:5000/translate
APP_TRANSLATION_LIBRE_API_KEY=
APP_TRANSLATION_TIMEOUT_MS=5000
APP_TRANSLATION_CACHE_TTL_SECONDS=86400
APP_TRANSLATION_CACHE_MAX_ENTRIES=5000
APP_TRANSLATION_MIN_INTERVAL_MS=150

# OCR settings
# Se usar READIUM_IMAGE_TAG=ocr, prefira APP_OCR_ENGINE=OCRMYPDF
APP_OCR_ENGINE=HEURISTIC
APP_OCR_SAMPLE_PAGES=10
APP_OCR_ASYNC_CORE_POOL_SIZE=1
APP_OCR_ASYNC_MAX_POOL_SIZE=2
APP_OCR_ASYNC_QUEUE_CAPACITY=8
APP_OCR_RUNNING_TIMEOUT_SECONDS=2400
APP_OCR_RECOVERY_FIXED_DELAY_MS=60000
APP_OCRMYPDF_COMMAND=ocrmypdf
APP_OCRMYPDF_LANGUAGES=eng+por
APP_OCRMYPDF_TIMEOUT_SECONDS=1800

# CORS
# Lista separada por virgula. Inclua origens web e mobile (Capacitor).
# Exemplo com VPN/IP fixo:
# APP_WEB_CORS_ALLOWED_ORIGIN_PATTERNS=http://100.71.22.87,http://100.71.22.87:7717,capacitor://localhost,ionic://localhost,http://localhost,http://127.0.0.1
APP_WEB_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost,http://127.0.0.1,capacitor://localhost,ionic://localhost
APP_WEB_CORS_ALLOW_CREDENTIALS=false
